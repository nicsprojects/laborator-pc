// Objectives:
// 1. configure I2C
// 2. comupaction over I2C
// 3. ADXL345 usage

// Components
// ADXL345 module
// Bidirectional level shifter

// Docs
// ADXL345 Datasheet: https://www.analog.com/media/en/technical-documentation/data-sheets/adxl345.pdf

#include "Arduino.h"
#include "avr8-stub.h"
#include "app_api.h" // only needed with flash breakpoints
#include <I2cMaster.h>
#include <Uart.h>

#define ADX345_I2C_ADDR 0x53
#define DATAX0 0x32

I2cMaster wire;
Uart uart;

void setup() {
    // initialize GDB stub
    debug_init();

    uart.init();
    wire.init();

    delay(500);

    // read ADXL DEVICE ID (expected response 0xE5)
    wire.sendStart();
    wire.writeAddrRead(ADX345_I2C_ADDR);
    char deviceId = 0x00;
    wire.readByte(deviceId);
    wire.sendStop();

    delay(500);

    // enable ADXL read
    wire.sendStart();
    wire.writeAddrWrite(ADX345_I2C_ADDR);
    wire.writeByte(0x2D);  // POWER_CTL register
    wire.writeByte(0x08);  // enable measurement mode
    wire.sendStop();

    delay(500);
}

void ADXL_readData() {
    // read X, Y, Z from ADXL and send to PC
    char xLow, xHigh, yLow, yHigh, zLow, zHigh;

    // Start I2C transaction to read data from DATAX0 register
    wire.sendStart();
    wire.writeAddrWrite(ADX345_I2C_ADDR);
    wire.writeByte(DATAX0);  // DATAX0 register address

    // Repeated start to read
    wire.sendStart();
    wire.writeAddrRead(ADX345_I2C_ADDR);
    wire.readByte(xLow);
    wire.readByte(xHigh);
    wire.readByte(yLow);
    wire.readByte(yHigh);
    wire.readByte(zLow);
    wire.readByte(zHigh);
    wire.sendStop();

    // Send data over UART
    uart.writeByte('X');
    uart.writeIntegerNumber((int16_t)((xHigh << 8) | xLow));
    uart.writeByte(' ');
    uart.writeByte('Y');
    uart.writeIntegerNumber((int16_t)((yHigh << 8) | yLow));
    uart.writeByte(' ');
    uart.writeByte('Z');
    uart.writeIntegerNumber((int16_t)((zHigh << 8) | zLow));
    uart.writeByte('\n');
}

void loop() {
    ADXL_readData();
    delay(500);
}
